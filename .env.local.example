# Copy this file to .env.local for local development.
# .env.local is gitignored so this file never leaves your machine.

DATABASE_URL="postgresql://dev:dev@localhost:5432/doai_calls_dev"

# NextAuth needs a secret even in dev. Value can be anything random locally.
AUTH_SECRET="dev-secret-not-secure-local-only"
AUTH_URL="http://localhost:4500"
AUTH_TRUST_HOST=true

# ---- Dev-only auth bypass ----
# When set, middleware skips session checks and requireTenant/requireSuperAdmin
# return a mock super-admin context pointing to the seeded DOAI org.
# NEVER set these on the VPS. They are gitignored via .env.local.
DEV_BYPASS_AUTH=1
NEXT_PUBLIC_DEV_BYPASS_AUTH=1
