# Database
DATABASE_URL=postgresql://user:password@localhost:5432/doai_calls

# Auth (NextAuth v5)
AUTH_SECRET=                              # openssl rand -base64 32
AUTH_URL=https://call.doaisystems.co.uk
AUTH_TRUST_HOST=true                      # required behind reverse proxy

# Email (for magic link sign-in)
EMAIL_SERVER_HOST=smtp.resend.com
EMAIL_SERVER_PORT=465
EMAIL_SERVER_USER=resend
EMAIL_SERVER_PASSWORD=                    # Resend API key or SMTP password
EMAIL_FROM=noreply@doaisystems.co.uk

# Vapi
VAPI_API_KEY=your-vapi-api-key
VAPI_WEBHOOK_SECRET=your-webhook-secret

# WhatsApp Cloud API (used by webhook verification only)
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=your-custom-verify-token
WHATSAPP_APP_SECRET=your-meta-app-secret

# Claude AI (shared key for all orgs unless overridden per-org)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Super-admin (for migration script)
SUPER_ADMIN_EMAIL=roy@doaisystems.co.uk
